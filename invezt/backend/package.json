{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon",
    "test": "node --test tests/portfolioController.test.js",
    "test:jest": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^genkit$": "<rootDir>/tests/__mocks__/genkit.js",
      "^@genkit-ai/(.*)$": "<rootDir>/tests/__mocks__/genkit.js",
      "^.*/ai/genkit\\.js$": "<rootDir>/tests/__mocks__/genkitai.js"
    }
  },
  "nodemonConfig": {
    "watch": [
      "src",
      ".env"
    ],
    "ext": "js,mjs,cjs,json,env",
    "ignore": [
      "*.txt",
      "server_logs*.txt",
      "startup_error.txt",
      "test_results*.txt",
      "src_server_logs.txt"
    ],
    "exec": "node src/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.3.1",
    "groq-sdk": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
